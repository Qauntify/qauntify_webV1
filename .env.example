# SEA-LION API keys — get them at https://playground.sea-lion.ai (Google sign-in)
# Symbols are spread across keys round-robin; add as many as you have.
# (SEALION_API_KEYS=key1,key2 and plain SEALION_API_KEY also work.)
SEALION_API_KEY1=your-sealion-key-here
SEALION_API_KEY2=
SEALION_API_KEY3=
SEALION_API_KEY4=

# Supabase project — Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Telegram signal alerts (optional — skipped when empty).
# Bot token from @BotFather; channel id from your Telegram channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# After applying supabase/schema.sql (playbook_chunks + match_playbook_chunks),
# seed vector playbook once: python -m signals.rag.seed
# (Local keyword playbook works even before seeding.)

# Trading Floor — fully separate from the signals engine cron and SEA-LION confirm keys.
# Schedule its own cron (e.g. every 15–30 min): GET /api/cron/floor?secret=<FLOOR_CRON_SECRET>
FLOOR_LLM_API_KEY_MACRO=
FLOOR_LLM_API_KEY_TECHNICAL=
FLOOR_LLM_API_KEY_NEWS=
FLOOR_LLM_API_KEY_PM=
FLOOR_LLM_BASE_URL=https://api.openai.com/v1
FLOOR_LLM_MODEL=
FLOOR_CRON_SECRET=
# Optional floor headlines (web only; signals engine uses its own RSS client)
CRYPTOPANIC_API_KEY=
