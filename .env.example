# SEA-LION API key — get one at https://playground.sea-lion.ai (Google sign-in)
SEALION_API_KEY=your-sealion-key-here

# Supabase project — Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Telegram signal alerts (optional — skipped when empty).
# Bot token from @BotFather; chat id from e.g. @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
