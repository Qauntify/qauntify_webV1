# SEA-LION API keys — get them at https://playground.sea-lion.ai (Google sign-in)
# Symbols are spread across keys round-robin; add as many as you have.
# (SEALION_API_KEYS=key1,key2 and plain SEALION_API_KEY also work.)
SEALION_API_KEY1=your-sealion-key-here
SEALION_API_KEY2=
SEALION_API_KEY3=
SEALION_API_KEY4=

# Supabase project — Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Telegram signal alerts (optional — skipped when empty).
# Bot token from @BotFather; channel id from your Telegram channel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
